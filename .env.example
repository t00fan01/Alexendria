# Environment Variables — Alexandria AI
# Copy this file to .env and fill in your own values.
# NEVER commit your real .env file. This .env.example is safe to commit.

# ─── Required ──────────────────────────────────────────────────────────────────
# Google Gemini API key (AI summarization, Q&A, quiz generation)
# Get one free: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# AssemblyAI API key (audio/video file transcription)
# Get one free: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# YouTube Data API key (optional, for richer metadata)
# Get one free: https://console.cloud.google.com/
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Feature Flags (change to 0/1 to toggle) ───────────────────────────────────
ENABLE_GEMINI=1
ENABLE_CHROMA=0
ENABLE_EMBEDDINGS=0
ENABLE_YOUTUBE_ASR=1
ENABLE_METADATA_FALLBACK=0
