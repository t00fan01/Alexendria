# COPY THIS FILE TO .env AND FILL WITH YOUR OWN VALUES
# Do not commit .env to GitHub.

# Example API keys
GOOGLE_API_KEY=your_google_api_key_here
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here

# Hackathon-fast defaults. Turn these on only when you want slower AI polish or persistence.
ENABLE_GEMINI=0
ENABLE_CHROMA=0
ENABLE_EMBEDDINGS=0
# Real transcript mode:
# 1) First try YouTube captions/auto-captions (free, no API key)
# 2) If unavailable, optionally fallback to AssemblyAI audio transcription
ENABLE_YOUTUBE_ASR=1

# Keep this OFF for real transcript-only behavior.
# If enabled, metadata text may be used when speech transcript is unavailable.
ENABLE_METADATA_FALLBACK=0
